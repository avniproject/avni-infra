# Rendered by the tanuh_superset role to {{ superset_container_env_file }}.
# Consumed by superset_config.py in the avniproject/tanuh-superset image.
#
# SUPERSET_DB_* point at Superset's OWN metadata DB (tanuh_reporting_superset_db
# on proddb02) — NEVER at tanuh_reporting_db or the shared Avni Superset metadata DB.
# SUPERSET_SECRET_KEY MUST stay stable across redeploys (vault); rotating it
# invalidates sessions and breaks encrypted secrets stored in the metadata DB.
SUPERSET_SECRET_KEY={{ superset_secret_key }}
SUPERSET_DB_NAME={{ superset_db_name }}
SUPERSET_DB_USER={{ superset_db_user }}
SUPERSET_DB_PASSWORD={{ superset_db_pass }}
SUPERSET_DB_URL={{ superset_db_host }}
SUPERSET_DB_PORT={{ superset_db_port }}
# Keep gunicorn workers low to stay within the ~2 GB container cap.
SERVER_WORKER_AMOUNT={{ superset_worker_amount }}
